{"extends": "./.nuxt/tsconfig.json", "compilerOptions": {"lib": ["ES2020", "DOM", "DOM.Iterable"], "target": "ES2020", "module": "ESNext", "moduleResolution": "bundler", "strict": false, "jsx": "preserve", "resolveJsonModule": true, "isolatedModules": true, "esModuleInterop": true, "forceConsistentCasingInFileNames": true, "skipLibCheck": true, "allowJs": true, "types": ["node"], "paths": {"~/*": ["./*"], "@/*": ["./*"]}}, "include": [".nuxt/nuxt.d.ts", ".nuxt/imports.d.ts", "**/*.ts", "**/*.vue"]}